{
  "permissions": {
    "allow": [
      "Bash(node -e \"const url = 'postgresql://user:password@host:5432/db'; console.log(url);\")",
      "Bash(npm install)"
    ],
    "deny": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [],
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [{ "command": "~/.claude/hooks/missing-hook.sh", "type": "command" }] }
    ]
  }
}
