# templates/snippets/ci/ci-nightly.yml.template
# Sourcing mode: customization (per specs/00-vision-and-license.md §"Sourcing modes")
# Tier-4 nightly workflow — full unit suite + full e2e suite. Runs on
# a cron schedule (default 2 AM UTC) plus manual workflow_dispatch.
# Same secrets-gate pattern as ci-pr-fast.yml.template's e2e-daily job.
#
# When you adopt this template, save it as
# `<consumer>/.github/workflows/nightly.yml` (strip the `.template`
# suffix). Search-and-replace the `{{...}}` tokens. Adapt the
# commented-out stack-specific setup steps.
#
# Canonical source for the cost/feedback rationale: docs/methodology.md
# §C "Test scheduling: match cost to feedback urgency."
#
# Authored: 2026-05-07
# License: CC0 1.0 (templates ship CC0 per specs/00-vision-and-license.md §"License")

name: nightly

on:
  schedule:
    # CHANGE ME: cron time. Default 2 AM UTC = 10 PM ET / 3 AM CET.
    # Off-peak hours so a long-running suite doesn't compete with
    # daytime work.
    - cron: "0 2 * * *"
  workflow_dispatch:

permissions:
  contents: read

jobs:
  nightly:
    name: Full unit + full e2e suite
    runs-on: ubuntu-latest

    steps:
      # CHANGE ME: rename E2E_DATABASE_URL to whichever secret
      # presence indicates "E2E env is configured."
      - name: Check E2E secrets
        id: secrets
        env:
          REQUIRED: "${{ secrets.E2E_DATABASE_URL }}"
        run: |
          if [ -n "$REQUIRED" ]; then
            echo "configured=true" >> "$GITHUB_OUTPUT"
          else
            echo "configured=false" >> "$GITHUB_OUTPUT"
            echo "::warning::E2E secrets not configured — running unit suite only."
          fi

      - uses: actions/checkout@v4

      # CHANGE ME: stack-specific setup. See ci-pr-fast.yml.template
      # for examples (Node, Python, Ruby, Go).
      #
      # # Example for Node:
      # - uses: actions/setup-node@v4
      #   with:
      #     node-version: "22"
      #     cache: "npm"
      # - name: Install dependencies
      #   run: npm ci

      - name: Full unit suite
        run: "{{TEST_FULL_CMD}}"

      # E2E setup runs only when secrets are present.
      # CHANGE ME: stack-specific E2E setup (browser install, DB seed, build).
      #
      # # Example for Node + Playwright:
      # - name: Install Playwright (all browsers)
      #   if: steps.secrets.outputs.configured == 'true'
      #   run: npx playwright install --with-deps
      # - name: Build app
      #   if: steps.secrets.outputs.configured == 'true'
      #   run: "{{BUILD_CMD}}"

      # CHANGE ME: replace with your full-e2e command.
      # No markdown placeholder for "full e2e" — the kit's vocabulary
      # has TEST_CI_CMD (PR gate) and TEST_FULL_CMD (full unit local)
      # but no e2e-specific entry. Substitute directly. Examples:
      #   npx playwright test            (all e2e suites)
      #   pytest tests/e2e               (full e2e directory)
      #   bundle exec rspec spec/e2e
      - name: Run full e2e suite
        if: steps.secrets.outputs.configured == 'true'
        run: |
          # TODO: substitute your full-e2e command (see comment above).
          echo "REPLACE THIS LINE with your full e2e command"
          exit 1

      - name: Upload e2e report on failure
        uses: actions/upload-artifact@v4
        if: failure() && steps.secrets.outputs.configured == 'true'
        with:
          name: nightly-e2e-report
          path: |
            playwright-report/
            test-results/
          retention-days: 14
